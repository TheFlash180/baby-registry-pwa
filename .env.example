# Copy to .env.local for local development. In CI these are GitHub repo secrets.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Note: there is intentionally NO admin password env var here. This is a static
# site — anything in a VITE_ env var ships to every visitor's browser in the JS
# bundle. The admin password lives server-side in the registry_settings table
# (see supabase/schema.sql) and every admin action is verified in Postgres.
